---
import { getPhase, padChapter, type Chapter } from "../lib/course";
interface Props { chapter: Chapter }
const { chapter } = Astro.props;
const phase = getPhase(chapter.phase)!;
---

<header class="reader-header">
  <button class="icon-button icon-button--menu" type="button" data-sidebar-open aria-expanded="false" aria-controls="reader-index" aria-label="打开课程索引">
    <span aria-hidden="true"></span><span aria-hidden="true"></span>
  </button>
  <a class="reader-header__mark" href="/course/"><b>MT</b><span>WYCKOFF</span></a>
  <p><span>PHASE {phase.roman}</span> / {phase.english} / CHAPTER {padChapter(chapter.number)}</p>
  <button class="icon-button" type="button" data-search-open aria-label="搜索全书">⌕</button>
</header>
