<dialog class="figure-dialog" data-figure-dialog aria-labelledby="figure-dialog-caption">
  <div class="figure-dialog__bar">
    <p class="eyebrow">FIGURE VIEW</p>
    <div class="figure-dialog__controls" role="group" aria-label="图表缩放">
      <button type="button" data-figure-zoom="out" aria-label="缩小">−</button><button type="button" data-figure-zoom="reset">100%</button><button type="button" data-figure-zoom="in" aria-label="放大">＋</button><button class="icon-button" type="button" data-figure-close aria-label="关闭大图">×</button>
    </div>
  </div>
  <div class="figure-dialog__viewport" data-figure-viewport><img src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" data-figure-dialog-image alt="" /></div>
  <p id="figure-dialog-caption" data-figure-dialog-caption></p>
</dialog>
