---
import BaseLayout from "../../components/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { course, getPhaseChapters, padChapter } from "../../lib/course";

const guide = {
  overview: course.frontMatter[9]?.text,
  learning: course.frontMatter.slice(11, 14).map((block) => block.text).join(" "),
  market: course.frontMatter[15]?.text,
  order: course.frontMatter[17]?.text,
  structure: course.frontMatter[20]?.text
};
---

<BaseLayout title="课程总览 · MT WYCKOFF" description="Wyckoff 专业交易方法六阶段二十四章课程总览" pageClass="course-page">
  <SiteHeader location="PROFESSIONAL TRADING TEXTBOOK · V5.1" />
  <main id="main-content">
    <section class="course-cover">
      <header class="course-cover__folio">
        <span>MT TRADING STUDIO</span><span>PROFESSIONAL TEXTBOOK</span><span>V5.1 · 2026</span>
      </header>

      <div class="course-cover__index" role="group" aria-label="课程规模">
        <p>COURSE</p><strong>06</strong><span>PHASES</span><strong>24</strong><span>CHAPTERS</span>
      </div>

      <div class="course-cover__statement">
        <p class="eyebrow">WYCKOFF PROFESSIONAL METHOD</p>
        <h1><strong>证据</strong>先于解释。<br />结构先于<strong>行动。</strong></h1>
        <p>从市场行为、结构判定到机构级执行与研究</p>
      </div>

      <aside class="course-cover__title">
        <p class="eyebrow">STUDENT EDITION</p>
        <h2><span>WYCKOFF</span>专业交易方法</h2>
        <p>一本把观察、解释、验证与行动连接为同一条证据链的数字研究教材。</p>
        <dl><div><dt>FORMAT</dt><dd>Digital textbook</dd></div><div><dt>EDITION</dt><dd>Version 5.1</dd></div></dl>
      </aside>

      <figure class="course-cover__plate">
        <img src="/course-assets/figures/image1.png" width="1693" height="929" alt="供需与价格分布示意图" />
        <figcaption><span>PLATE 01</span><p>Price · Volume · Time · Structure</p></figcaption>
      </figure>

      <nav class="course-cover__tabs" aria-label="六个学习阶段">
        {course.phases.map((phase) => <a href={`/phase/${phase.slug}/`}><span>{String(phase.number).padStart(2, "0")}</span><small>{phase.english}</small></a>)}
      </nav>

      <div class="course-cover__start">
        <p>{course.frontMatter[5]?.text}</p>
        <a class="text-link" href={`/chapter/${course.chapters[0].slug}/`} data-continue-link><span data-continue-label>从第一章开始</span><span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="progress-board" aria-labelledby="progress-title" data-course-dashboard>
      <div class="progress-board__heading">
        <p class="eyebrow" id="progress-title">READING POSITION</p>
        <p data-last-position>尚未开始学习</p>
      </div>
      <div class="progress-board__segments" role="group" aria-label="24 章阅读进度">
        {course.chapters.map((chapter) => <i data-progress-segment={chapter.number}><span class="sr-only">第 {chapter.number} 章</span></i>)}
      </div>
      <p><span data-completed-chapters>0</span> / 24 · <span data-total-progress>0%</span></p>
      <div class="progress-board__phases" hidden>
        {course.phases.map((phase) => <span data-phase-progress={phase.number}>0%</span>)}
      </div>
    </section>

    <section class="course-guide" aria-labelledby="guide-title">
      <div class="course-guide__title">
        <p class="eyebrow">HOW THE TEXTBOOK IS ORGANIZED</p>
        <h2 id="guide-title">不是术语目录，<br />而是一条<strong>证据链。</strong></h2>
      </div>
      <div class="course-guide__lead"><p>{guide.overview}</p><p>{guide.structure}</p></div>
      <article><span>01</span><h3>学习主线</h3><p>{guide.learning}</p></article>
      <article><span>02</span><h3>市场与案例</h3><p>{guide.market}</p></article>
      <article><span>03</span><h3>章节顺序</h3><p>{guide.order}</p></article>
    </section>

    <section class="curriculum" aria-labelledby="curriculum-title">
      <p class="curriculum__word" aria-hidden="true">CONTENT</p>
      <div class="curriculum__body">
        <header class="curriculum__header">
          <div><p class="eyebrow">SIX PHASES · TWENTY-FOUR CHAPTERS</p><h2 id="curriculum-title">课程结构</h2></div>
          <p>从证据语言到组合治理，24 章沿一条连续的专业推理路径展开。</p>
        </header>
        <div class="curriculum__list">
          {course.phases.map((phase) => (
            <article class="curriculum-phase" data-phase-card={phase.number}>
              <a class="curriculum-phase__header" href={`/phase/${phase.slug}/`}>
                <span class="curriculum-phase__roman">{String(phase.number).padStart(2, "0")}</span>
                <div><p class="eyebrow">{phase.english}</p><h3>{phase.title}</h3></div>
                <p>{phase.statement}</p><span aria-hidden="true">↗</span>
              </a>
              <ol>
                {getPhaseChapters(phase).map((chapter) => (
                  <li data-chapter-card={chapter.number}><a href={`/chapter/${chapter.slug}/`}><span>{padChapter(chapter.number)}</span><strong>{chapter.title}</strong><small data-card-progress={chapter.number}>未开始</small></a></li>
                ))}
              </ol>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <footer class="site-footer"><div class="wordmark wordmark--footer"><span class="wordmark__mt">MT</span><span class="wordmark__wyckoff">WYCKOFF</span></div><p>Professional Trading Textbook · Version 5.1 Student Edition</p><a href="#main-content">返回顶部 ↑</a></footer>
</BaseLayout>
